{
  "manifest_version": 3,
  "name": "B站专注模式-稳健版",
  "version": "1.3",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "*://www.bilibili.com/*",
    "*://search.bilibili.com/*"
  ],
  "action": {},
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://www.bilibili.com/*", "*://search.bilibili.com/*"],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_start"
    }
  ]
}